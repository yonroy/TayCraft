# ============ Supabase ============
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Connect → ORM. App runtime dùng transaction pooler (6543), migration dùng session pooler (5432).
DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-1-...pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-1-...pooler.supabase.com:5432/postgres

# ============ Khóa học ============
COURSE_PRICE_VND=199000

# ============ Ngân hàng / VietQR ============
# BANK_CODE: mã ngân hàng theo VietQR (vd: VCB, TCB, ACB, MB, BIDV, VPB...)
BANK_CODE=VCB
BANK_ACCOUNT_NUMBER=0123456789
BANK_ACCOUNT_NAME=NGUYEN VAN A

# ============ SePay (đối soát tự động — điền khi đã đăng ký) ============
# Tự đặt 1 chuỗi bí mật, cấu hình y hệt trong SePay webhook (Authorization: Apikey <key>)
SEPAY_WEBHOOK_API_KEY=doi-thanh-chuoi-bi-mat-cua-ban

# ============ Admin ============
# Danh sách email admin (cách nhau bởi dấu phẩy) — được phép xác nhận đơn thủ công
ADMIN_EMAILS=tranminhtoan14062001@gmail.com

# ============ App ============
NEXT_PUBLIC_SITE_URL=http://localhost:3000
